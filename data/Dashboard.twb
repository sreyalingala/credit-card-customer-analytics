      <aliases enabled='yes' />
      <column aggregation='CountD' caption='Attrition Flag (copy)' datatype='string' default-role='measure' default-type='quantitative' name='[Attrition Flag (copy)_4142537649693487106]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Attrition_Flag]' />
      </column>
      <column caption='Attrition Flag' datatype='string' name='[Attrition_Flag]' role='dimension' type='nominal' />
      <column caption='Avg Open To Buy' datatype='real' name='[Avg_Open_To_Buy]' role='measure' type='quantitative' />
      <column caption='Avg Utilization Ratio' datatype='real' name='[Avg_Utilization_Ratio]' role='measure' type='quantitative' />
      <column caption='Clientnum' datatype='integer' name='[CLIENTNUM]' role='measure' type='quantitative' />
      <column caption='Churn Rate' datatype='real' default-format='p0.0%' name='[Calculation_4142537649703407620]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Attrition_Flag] = &quot;Attrited Customer&quot; THEN 1 ELSE 0 END) &#10;/&#10;COUNT([CLIENTNUM])' />
      </column>
      <column caption='Total Customers' datatype='integer' name='[Calculation_4142537649708675077]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([CLIENTNUM])' />
      </column>
      <column caption='Transaction Gap' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[Calculation_4142537649709166598]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [Attrition_Flag] = &quot;Existing Customer&quot;&#10;THEN [Total_Trans_Amt]&#10;END)&#10;-&#10;AVG(IF [Attrition_Flag] = &quot;Attrited Customer&quot;&#10;THEN [Total_Trans_Amt]&#10;END)' />
      </column>
